<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.turistika.controller.AdminPodaciController"
      alignment="CENTER" spacing="20"
      style="-fx-padding: 40;">
    <Label text="Upravljanje podacima"
           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <Separator/>
    <Button text="Obrisi sve podatke"
            onAction="#obrisiSvePodatke"
            prefWidth="200"
            style="-fx-background-color: red; -fx-text-fill: white;"/>
    <Button text="Ucitaj test podatke"
            onAction="#ucitajTestPodatke"
            prefWidth="200"
            style="-fx-background-color: orange; -fx-text-fill: white;"/>
    <Label fx:id="statusLabel" text="" style="-fx-text-fill: green;"/>
</VBox>
